import tkinter as tk # Standard Python interface for creating windows and buttons
from tkinter import messagebox, simpledialog 
# Tools for pop-up alerts and text input boxes
from tkinter import messagebox, simpledialog
import random # For generating unpredictable dance move sequences
import time # For tracking how fast a player responds or duration of the game
import threading # Allows the game to run timers in the background without freezing the UI
import json # Used to convert Python lists/dictionaries into a text format for saving
import os # Helps the program check if files exist on your computer's hard drive

# -------------------------------
# 1. SESSION & LEADERBOARD LOGIC
# -------------------------------
class DanceSession:
    def __init__(self, dancer_name: str): # Stores the player's name and initializes their starting stats
        self.dancer = dancer_name
        self.reset_session()

    def reset_session(self): # Sets all counters to zero for a fresh start
        self.score = 0 # Numerical points earned
        self.total_attempts = 0 # Total moves shown to the player
        self.correct_answers = 0 # Number of moves the player successfully matched
        self.performance_ratio = 0.0 # Accuracy percentage

    def update_performance(self): # Calculates accuracy: (Correct Hits / Total Moves) * 100
        if self.total_attempts > 0:
            self.performance_ratio = (self.correct_answers / self.total_attempts) * 100

class LeaderboardManager: # Defines the filename where high scores are permanently saved
    FILE = "leaderboard.json"

    @staticmethod
    def save_score(name, score, dance): # 1. Retrieve the existing high score list
        data = LeaderboardManager.load_scores() # 2. Add the new player's data (Name, Rounded Score, and Dance Type)
        data.append({"name": name, "score": round(score, 1), "dance": dance}) # 3. Sort the list from highest score to lowest (reverse=True)
        # 4. Use slicing [:10] to only keep the top 10 players on the board
        data = sorted(data, key=lambda x: x['score'], reverse=True)[:10] # 5. Write the updated list back to the JSON file
        with open(LeaderboardManager.FILE, "w") as f:
            json.dump(data, f)

    @staticmethod
    def load_scores(): # Check if the file exists; if not, return an empty list to avoid errors
        if not os.path.exists(LeaderboardManager.FILE):
            return []
        with open(LeaderboardManager.FILE, "r") as f: # Open the file and convert the JSON text back into a Python list
            return json.load(f)

# -------------------------------
# 2. MAIN APPLICATION CLASS
# -------------------------------
class DanceStudioApp: # Define the main application class for the Dance Studio app
    def __init__(self, root): # The initialization method that runs when you first create the app
        self.root = root # Store the main window (root) as an attribute of the class
        self.root.title("Pro Dance Trainer v2.0 - Leaderboard Edition") # Set the title at the top of the window
        self.root.geometry("800x900")   # Set the starting width and height of the window in pixels

            # A dictionary storing dance routines: "Name": ([List of Moves], Speed/Delay, "Difficulty")
        self.dances = { 
            "The Git Up": (["Two-Step", "Cowboy Boogie", "The Hoedown", "Left Slide", "Take a Sip", "Crisscross"], 1.3, "Easy"),
            "Renegade": (["Clap Clap", "Hit the Woah", "Wave", "Shoulder Tap", "Hip Swing", "Confident Pose"], 1.3, "Easy"),
            "Savage": (["Shimmy", "Classy Cross", "Hair Flip", "Drive the Car", "Sassy Hip", "Nasty Snap", "Body Roll"], 1.3, "Easy"),
            "The Nae Nae": (["One Arm Up", "Sway Side to Side", "Bend Knees", "Whip Motion", "Swag Lean", "Freestyle", "Stanky Leg", "Shoulder Bounce"], 1.2, "Normal"),
            "Supalonely": (["Shoulder Pull", "Head Tilt", "Air Drumming", "Marching Step", "Hip Push", "Body Roll", "The Clock", "Peace Sign", "Shrug"], 1.2, "Normal"),
            "Blinding Lights": (["Running in Place", "Dabbing", "Leg Kicks", "Arm Swings", "Jumping Jacks", "Spinning", "The Sprint", "Side Shuffle", "Neon Glow Walk", "Retro Slide", "Hand Wave", "Quick Kick", "Pose"], 1.0, "Hard"),
            "Tap In": (["Gather Head", "Point Right/Left", "Flower Hand", "Turn Around", "Dice Throw", "W Motion", "Wrist Flick", "Icy Pose", "Lip Swipe", "The Money Count", "Shoulder Pop", "Hair Pull back", "Step-Touch"], 1.0, "Hard"),
            "Say So": (["Punch", "Arm Roll", "Click", "Fist/Faux Kiss", "Body Roll", "Walk Away", "Hip Sway", "Heart Hands", "Hair Twirl", "Disco Point", "Spin Turn", "Shoulder Shimmy", "Final Strike"], 1.0, "Hard"),
        }
        
        self.all_moves = list(set([m for moves, d, meta in self.dances.values() for m in moves]))         # Collect every unique move from all dances into a single list for the "multiple choice" test mode
        self.session = DanceSession("Pro Dancer") # Initialize a separate tracking object for the user's current session
        self.current_dance = None # Placeholder to track which dance the user just picked
        self.test_step = 0 # Tracks which step the user is currently on during an assessment
        self.mistakes = 0 # Tracks how many wrong answers the user has given
        self.is_paused = False # A flag to check if the dance display should be frozen
        self.colors = ["#FF5733", "#33FF57", "#3357FF", "#F333FF", "#FF33A1", "#F3FF33"] # List of hex codes for colorful text

        self.setup_main_menu() # Call the method to build the first screen the user sees

        # Creates the main menu layout
    def setup_main_menu(self): 
        self.clear_screen() # Wipe the window clean of any previous menus/widgets
        self.main_frame = tk.Frame(self.root, bg="#1a1a1a") # Create a container (Frame) with a dark background
        self.main_frame.pack(fill="both", expand=True) # Make the container fill the entire window

         # Create a header label with fancy font and colors
        tk.Label(self.main_frame, text="🕺 DANCE STUDIO v2 💃", font=("Verdana", 24, "bold"), fg="cyan", bg="#1a1a1a").pack(pady=20)

        # Create a box area where the dance moves will actually be displayed
        self.visual_box = tk.Frame(self.main_frame, width=400, height=150, bg="#333", relief="ridge", bd=5)
        self.visual_box.pack(pady=10)
        self.visual_box.pack_propagate(False) # Stop the box from shrinking to fit the text inside

        # The actual label where the name of the move (e.g., "Body Roll") appears
        self.move_display = tk.Label(self.visual_box, text="READY?", font=("Impact", 40), fg="white", bg="#333")
        self.move_display.pack(expand=True)

        # A smaller status label to give the user instructions
        self.status = tk.Label(self.main_frame, text="Select a routine...", fg="#00FF00", bg="#1a1a1a")
        self.status.pack(pady=10)

        # Container for the dance selection buttons
        btn_zone = tk.Frame(self.main_frame, bg="#1a1a1a")
        btn_zone.pack() # Loop through the dance dictionary and create a button for each one
        for name in self.dances: # lambda n=name: self.play_dance(n) tells the button to run play_dance with that specific dance name when clicked
            tk.Button(btn_zone, text=f"{name} ({self.dances[name][2]})", width=35, 
                      command=lambda n=name: self.play_dance(n)).pack(pady=2)

        # Button to open the leaderboard
        tk.Button(self.main_frame, text="🏆 VIEW LEADERBOARD", font=("Arial", 10, "bold"), 
                  bg="#f1c40f", command=self.show_leaderboard).pack(pady=15)

        # A small frame at the bottom for utility buttons
        nav_frame = tk.Frame(self.main_frame, bg="#1a1a1a")
        nav_frame.pack()
        tk.Button(nav_frame, text="Reset Session", command=self.reset_session_ui).pack(side="left", padx=5)
        tk.Button(nav_frame, text="View Stats", command=self.show_stats).pack(side="left", padx=5)

    # Removes every widget (button, label, etc.) currently in the window to make room for a new screen
    def clear_screen(self):
        for widget in self.root.winfo_children():
            widget.destroy()

    # Starts the visual display of a dance routine
    def play_dance(self, name):
        self.current_dance = name
        moves, delay, _ = self.dances[name]
        # A nested function that will run in the background so the app doesn't freeze
        def run():
            for i, move in enumerate(moves): # Loop through every move in the routine
                while self.is_paused: time.sleep(0.1) # If paused, wait here and do nothing
                # Update the status text safely using 'after' to talk to the main thread
                self.root.after(0, lambda m=move, idx=i: self.status.config(text=f"STEP {idx + 1}: {m}"))
                # Randomly change the color of the move text to make it look like a dance floor
                self.root.after(0, lambda m=move: self.move_display.config(text=m, fg=random.choice(self.colors)))
                time.sleep(delay) # Wait for the specified amount of time before showing the next move
            self.root.after(0, self.prompt_choice) # When the dance is over, ask if they want to take the test
        # Start the 'run' function on a separate "thread" so the user can still click buttons
        threading.Thread(target=run, daemon=True).start()

    # Asks the user if they want to take the assessment test
    def prompt_choice(self):
        if messagebox.askyesno("Assessment", "Are You Ready To Test Your Step Knowledge?"):
            self.start_testing_mode() # Start the multiple choice test
        else:
            self.setup_main_menu() # Go back to the main menu

    # Sets up the testing screen layout
    def start_testing_mode(self):
        self.clear_screen()
        self.test_step = 0 # Start at the first move
        self.mistakes = 0 # Start with zero mistakes
        self.session.reset_session() # Wipe the current session stats
        
        self.test_frame = tk.Frame(self.root, bg="#2c3e50") # Use a different color for "Test Mode"
        self.test_frame.pack(fill="both", expand=True)

        tk.Label(self.test_frame, text="ASSESSMENT MODE", font=("Verdana", 28, "bold"), fg="#f1c40f", bg="#2c3e50").pack(pady=20)
        tk.Label(self.test_frame, text="Get three wrong and you fail!", font=("Arial", 14), fg="#e74c3c", bg="#2c3e50").pack(pady=5)

        # Label that shows things like "Step 2/10 | Mistakes: 1/3"
        self.progress_label = tk.Label(self.test_frame, text="", font=("Arial", 12), fg="white", bg="#2c3e50")
        self.progress_label.pack(pady=5)

        # Container for the answer buttons
        self.choice_container = tk.Frame(self.test_frame, bg="#2c3e50")
        self.choice_container.pack(pady=30)
        self.render_test_buttons()

    # Generates the multiple-choice buttons for the current step in the test
    def render_test_buttons(self):
        # Clear the previous set of buttons
        for w in self.choice_container.winfo_children(): w.destroy()
        sequence = self.dances[self.current_dance][0] # Get the list of correct moves

        # Check if we still have more moves to test
        if self.test_step < len(sequence):
            # Update the progress display
            self.progress_label.config(text=f"Step: {self.test_step + 1}/{len(sequence)} | Mistakes: {self.mistakes}/3")
            correct = sequence[self.test_step] # The actual next move in the routine
            # Pick 3 random wrong moves from the master list
            others = [m for m in self.all_moves if m != correct]
            options = random.sample(others, 3) + [correct]
            random.shuffle(options) # Shuffle so the correct answer isn't always at the end

            # Create a button for each option
            for opt in options:
                tk.Button(self.choice_container, text=opt, width=25, font=("Arial", 11), 
                          command=lambda o=opt: self.verify_move(o)).pack(pady=5)
        else:
            # If the user finished all steps, go to the final screen
            self.finish_assessment()

    # Checks if the button the user clicked is the correct move
    def verify_move(self, chosen):
        sequence = self.dances[self.current_dance][0]
        correct = sequence[self.test_step]
        self.session.total_attempts += 1 # Log that they made an attempt

        if chosen == correct:
            self.session.correct_answers += 1 # Log a correct answer
            self.test_step += 1 # Move to the next move in the dance
            self.render_test_buttons() # Update the buttons for the next step
        else:
            self.mistakes += 1 # Log a mistake
            if self.mistakes >= 3:
                # If they hit 3 mistakes, they fail and go back to menu
                messagebox.showerror("FAILED", "Three strikes! Returning to menu.")
                self.setup_main_menu()
            else:
                # Show a warning and let them try the current step again
                messagebox.showwarning("WRONG", f"Incorrect! Strike {self.mistakes}/3")
                self.render_test_buttons()

    # Runs when the user completes a full dance assessment successfully
    def finish_assessment(self):
        self.session.update_performance() # Calculate the percentage score
        score = self.session.performance_ratio
        messagebox.showinfo("Success", f"Score: {score:.1f}%")

        # Ask for their name to save to the leaderboard        
        name = simpledialog.askstring("High Score", "Enter your name for the leaderboard:")
        if name:
            # Tell the LeaderboardManager to save this result to a file/list
            LeaderboardManager.save_score(name, score, self.current_dance)
        self.setup_main_menu()

    # Pulls data from the LeaderboardManager and shows it in a popup
    def show_leaderboard(self):
        scores = LeaderboardManager.load_scores() # Load the list of saved high scores
        board_text = "🏆 TOP 10 DANCERS 🏆\n" + "-"*30 + "\n"
        if not scores:
            board_text += "No scores yet!"
        # Loop through the top scores and format them as a numbered list
        for i, entry in enumerate(scores):
            board_text += f"{i+1}. {entry['name']} - {entry['score']}% ({entry['dance']})\n"
        
        messagebox.showinfo("Leaderboard", board_text)

    # Resets all current session data to zero
    def reset_session_ui(self):
        self.session.reset_session()
        messagebox.showinfo("Reset", "Session cleared.")

    # Shows a popup with the current user's performance statistics
    def show_stats(self):
        self.session.update_performance()
        msg = f"Dancer: {self.session.dancer}\nPerformance: {self.session.performance_ratio:.1f}%"
        messagebox.showinfo("Stats", msg)

